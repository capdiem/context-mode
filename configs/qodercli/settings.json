{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Grep|WebFetch|Task|mcp__",
        "hooks": [
          {
            "type": "command",
            "command": "context-mode hook qodercli pretooluse"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "context-mode hook qodercli posttooluse"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "context-mode hook qodercli userpromptsubmit"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
        "type": "command",
        "command": "context-mode hook qodercli stop"
      }
    ]
  }
]
  }
}
